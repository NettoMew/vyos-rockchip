# 70-rockchip-rk3528.config — RK3528（Radxa E20C / MangoPi M28K）支持，
# 叠加在通用 arm64 vyos_defconfig 之上。由 vyos-build 的 build-kernel.sh 经
# config/*.config glob 自动 merge（merge_config.sh，后者覆盖前者）。
#
# 官方 arm64 defconfig 有 ARCH_ROCKCHIP=y 但缺以下三类要害，缺一不可启动：
#   MMC_DW_ROCKCHIP（SD 控制器）、PCIE_ROCKCHIP_DW_HOST + NANENG combo PHY
#   （RK3528 的 PCIe 是 DesignWare 控制器，E20C 第二网口 r8169 挂其上）、
#   MOTORCOMM_PHY（E20C RGMII 口的 YT8531C PHY）。
# 启动链路（控制台/时钟/存储/网卡）一律内建（=y），不赌 initrd 模块顺序。

## SoC 基础设施
CONFIG_COMMON_CLK_ROCKCHIP=y
CONFIG_CLK_RK3528=y
CONFIG_PINCTRL_ROCKCHIP=y
CONFIG_ROCKCHIP_IODOMAIN=y
CONFIG_ROCKCHIP_PM_DOMAINS=y
CONFIG_ROCKCHIP_THERMAL=y
CONFIG_NVMEM_ROCKCHIP_OTP=y
CONFIG_NVMEM_ROCKCHIP_EFUSE=y
CONFIG_DW_WATCHDOG=y
CONFIG_RTC_DRV_HYM8563=y
CONFIG_I2C=y
CONFIG_I2C_RK3X=y
# SPI 子系统核心：vyos_defconfig 默认 # CONFIG_SPI is not set。缺它则 SPI_ROCKCHIP
# （在 Kconfig 的 `if SPI` 块内）与 MFD_RK8XX_SPI（depends on SPI，rk806 SPI PMIC，见 72
# 片段）都会被 olddefconfig 静默丢弃 —— E52C(RK3582) 的 rk806 挂在 spi2，缺它则 rk806 不
# probe → 它供电的 eMMC/SD/PCIe 全 deferred → live-boot 找不到根盘死循环。I2C 早有核心
# （上行），SPI 此前漏配，仅 e52c（唯一 SPI PMIC 板）触发；其它板无 SPI 外设，无害死代码。
CONFIG_SPI=y
CONFIG_SPI_ROCKCHIP=y
CONFIG_PWM=y
CONFIG_PWM_ROCKCHIP=y
CONFIG_GPIO_ROCKCHIP=y
CONFIG_ROCKCHIP_SARADC=y

## 供电
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_GPIO=y
CONFIG_REGULATOR_PWM=y

## CPU 调频（RK3528 CPU 时钟经 BL31 的 SCMI 暴露）
CONFIG_ARM_SCMI_PROTOCOL=y
CONFIG_COMMON_CLK_SCMI=y
CONFIG_CPUFREQ_DT=y
CONFIG_CPUFREQ_DT_PLATDEV=y

## 存储 — SD/eMMC（启动关键）
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_PWRSEQ_SIMPLE=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_OF_DWCMSHC=y

## 以太网 — gmac（RGMII，YT8531C）+ PCIe r8169
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_DWMAC_GENERIC=y
CONFIG_DWMAC_ROCKCHIP=y
CONFIG_PHYLIB=y
CONFIG_MOTORCOMM_PHY=y
CONFIG_REALTEK_PHY=y
CONFIG_ROCKCHIP_PHY=y
CONFIG_R8169=y

## PCIe — DesignWare 控制器 + naneng combo PHY
CONFIG_PCI=y
CONFIG_PCIE_ROCKCHIP_DW_HOST=y
CONFIG_PHY_ROCKCHIP_NANENG_COMBO_PHY=y

## USB
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_HCD_PLATFORM=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_OHCI_HCD_PLATFORM=y
CONFIG_USB_DWC3=y
CONFIG_USB_STORAGE=y
CONFIG_PHY_ROCKCHIP_INNO_USB2=y

## LED（路由器状态灯）
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_GPIO=y
# LEDS_PWM：E52C 的 LAN/WAN 灯是 DTS 的 pwm-leds（green:lan@pwm14 / green:wan@pwm11，
# 都 status=okay；PWM_ROCKCHIP 已 =y）。缺此驱动则两个 PWM LED 根本不注册（真机实测
# /sys/class/leds 只剩 gpio 的 green:status）→ 网口灯不亮。与 immortalwrt config-6.18 一致。
# 其它板若无 pwm-leds 节点则 inert，无副作用。
CONFIG_LEDS_PWM=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y
CONFIG_LEDS_TRIGGER_NETDEV=y

## OLED — SSD1306 128x32 (m28k oled@3c)：DRM ssd130x → fbdev emulation → /dev/fb0。
## DRM core/KMS/FBDEV_EMULATION 在 vyos_defconfig 已 =y，这里只加 ssd130x 本体（模块）。
CONFIG_DRM_SSD130X=m
CONFIG_DRM_SSD130X_I2C=m
