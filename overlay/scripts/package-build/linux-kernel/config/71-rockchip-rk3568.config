# 71-rockchip-rk3568.config — RK3568（NanoPi R5S）增量，叠加在 70-rockchip-rk3528
# 与通用 vyos_defconfig 之上（merge_config.sh 按 glob 全量合并，RK3528/RK3568 片段
# 共存于一个内核——主线"一个内核带全 SoC"同构，互不冲突）。
#
# RK3568 的启动/网卡要害绝大多数已由 70-rk3528 片段覆盖（同为 Rockchip：
# MMC_DW_ROCKCHIP、PCIE_ROCKCHIP_DW_HOST、DWMAC_ROCKCHIP、STMMAC、REALTEK_PHY、
# combo PHY、LED netdev/heartbeat 等全是 =y 且 SoC 无关）；CLK_RK3568 在 vyos_defconfig
# 已 =y。R5S 相对 RK3528 唯一缺的启动件是 PCIe v3 控制器用的 Synopsys PCIe3 PHY：
# 两个 RTL8125 2.5G 网卡挂在 pcie3x1/pcie3x2 上，没有这个 PHY 则 PCIe3 不 link、
# 网卡不枚举。RK3528 没有 PCIe3，故该 PHY 对 e20c/m28k 是死代码，零副作用。
CONFIG_PHY_ROCKCHIP_SNPS_PCIE3=y

# RK809 PMIC（i2c@fdd40000 上的 pmic@20）——R5S 启动命脉：它的 regulator 供电
# SWITCH_REG1(vcc_3v3)/LDO_REG5(vccio_sd)/DCDC_REG5(vcc_1v8) 喂 gmac0(WAN)、sdmmc0(SD)、
# sdhci(eMMC)、io-domains。RK3528 板用别的 PMIC，故 70 片段没有；缺它则 rk809 不 probe →
# 上述 regulator 永不就位 → 网卡/MMC 永久 deferred probe → live-boot 找不到根设备死循环。
# 必须内建(=y)：MMC 是根所在，不能赌 initrd 模块序。MFD_RK8XX 覆盖 rk805/808/809/817。
CONFIG_MFD_RK8XX=y
CONFIG_MFD_RK8XX_I2C=y
CONFIG_REGULATOR_RK808=y
CONFIG_COMMON_CLK_RK808=y
