# 72-rockchip-rk3588.config — RK3588/RK3588S/RK3582（Radxa E52C）增量，叠加在
# 70-rockchip-rk3528 + 71-rockchip-rk3568 与通用 vyos_defconfig 之上（merge_config.sh
# 按 glob 全量合并，RK3528/RK3568/RK3588 片段共存于一个内核——主线“一个内核带全 SoC”
# 同构，互不冲突）。E52C 是 RK3582（= RK3588S 残核 bin），纯主线 rk3582-radxa-e52c.dts。
#
# 启动/网卡要害大多已由 70/71 覆盖（同为 Rockchip：MMC_DW_ROCKCHIP、PCIE_ROCKCHIP_DW_HOST、
# NANENG combo PHY、STMMAC、REALTEK_PHY、MFD_RK8XX(+_I2C)、REGULATOR_RK808、LED netdev 等
# 全 =y 且 SoC 无关）。E52C 两个 RTL8125 挂 pcie2x1l1/l2（combo PHY，70 已覆盖），不走
# RK3568 的 SNPS PCIe3。相对 70/71 唯一缺的三件，全部 RK3588 专属：

# ① RK3588 时钟控制器——整机命脉（vyos_defconfig 只有 CLK_RK3568）。缺它所有 RK3588
#    外设拿不到时钟 → 不 probe。RK3528/3568 板不引用此 clk，死代码零副作用。
CONFIG_CLK_RK3588=y

# ② rk806 PMIC（E52C 在 spi2 上、system-power-controller）——启动命脉，等价 R5S 的
#    rk809 但走 SPI。71 片段已有 MFD_RK8XX_I2C（rk809）；rk806 是 SPI 变体，需 _SPI。
#    rk806 的 regulator 由 rk808-regulator.c（已 =y 的 REGULATOR_RK808）驱动，无独立符号。
#    缺它则 rk806 不 probe → 它供电的 vcc_3v3_s3/vccio_sd/vcc_1v8 等永不就位 → eMMC/SD/
#    PCIe 全 deferred probe → live-boot 找不到根设备死循环（同 R5S 缺 rk809 的坑）。必须 =y。
#    ⚠ 依赖前提（真机首测栽在这）：MFD_RK8XX_SPI 的 Kconfig 是 `depends on SPI && OF`，而
#    vyos_defconfig 默认 # CONFIG_SPI is not set → 本 =y 被 olddefconfig 静默丢弃、rk806
#    整个没编进内核。SPI 核心 CONFIG_SPI=y 已补在 70 片段（与 SPI_ROCKCHIP 同处）。动这里前
#    先确认 70 的 SPI 仍在。
CONFIG_MFD_RK8XX_SPI=y

# ③ rk8602/rk8603（i2c0/i2c2 上的大核 + NPU 电源，compatible rockchip,rk8602 → fan53555.c）。
#    boot 跑在小核（A55，rk806 供 vdd_cpu_lit）不依赖它；但开核放出的大核（A76 cluster）
#    要靠 rk8602/rk8603 供电才能上线/调频。缺它大核无 regulator → 开核拿不到大核。
CONFIG_REGULATOR_FAN53555=y

# ④ USB3：RK3588/RK3582 的 USB3 口用 USBDP 组合 PHY（phy-rockchip-usbdp.c），与 RK3568 的
#    NANENG combo PHY 不是一回事。e52c.dts 的 usb_host0_xhci(=fc000000.usb,dr_mode=host)
#    引用 &usbdp_phy0 → 缺此 PHY 则 dwc3 报 "failed to initialize core"、USB3 口不工作
#    （真机首启 dmesg 实测；USB2 走 INNO_USB2 仍可用）。e52c 无 Type-C 硬件，但 USBDP 的
#    Kconfig 偏偏 `depends on TYPEC`，故须连带开裸 TYPEC=y（只开子系统核心，不带任何 typec
#    控制器驱动）——与 immortalwrt config-6.18（同款 6.18 内核）一致，非臆测。RK3528/3568
#    无 usbdp_phy，inert 死代码。
CONFIG_TYPEC=y
CONFIG_PHY_ROCKCHIP_USBDP=y
